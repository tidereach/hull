# cplt-sndbx sandbox configuration.
# Copy to .env and fill in HOST_UID and HOST_GID before building:
#   cp .env.example .env && ./setup.sh

# Agent CLI to bake into the image at build time.
# Values: copilot | claude | none
AGENT_CLI=copilot

# Host user identity — used to match volume ownership inside the container.
# Populated automatically by setup.sh; override if needed.
HOST_UID=
HOST_GID=

# Host directory mounted read-write as the active workspace inside the container.
# This is the only writable host-bind source-code mount.
WORKSPACE_DIR=./workspace

# Colon-separated host paths mounted read-only at /work/repos/<basename>.
# Example: REPO_PATHS=/home/you/myapp:/home/you/libs
REPO_PATHS=

# Anthropic/Copilot tokens (injected at runtime, never baked into the image).
ANTHROPIC_API_KEY=
COPILOT_GITHUB_TOKEN=

# Named volume name for the session-streams Airlock feed.
# Change this to run parallel stacks without collision.
SESSION_STREAMS_VOLUME=session-streams
