{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "cwd": ".",
        "command": ".venv/bin/python integrations/copilot/hooks/session_start.py",
        "timeout": 60
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "cwd": ".",
        "command": ".venv/bin/python integrations/copilot/hooks/user_prompt_submit.py",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "cwd": ".",
        "command": ".venv/bin/python integrations/copilot/hooks/pre_tool_use.py",
        "timeout": 30
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "cwd": ".",
        "command": ".venv/bin/python integrations/copilot/hooks/post_tool_use.py",
        "timeout": 30
      }
    ],
    "Stop": [
      {
        "type": "command",
        "cwd": ".",
        "command": ".venv/bin/python integrations/copilot/hooks/stop.py",
        "timeout": 15
      }
    ]
  }
}
