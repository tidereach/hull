{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    //"CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_EFFORT_LEVEL": "medium",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "CLAUDE_CODE_BRIEF": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    //"CLAUDE_CODE_ENABLE_EXPERIMENTAL_ADVISOR_TOOL": "1",
    "CLAUDE_CODE_ENABLE_TASKS": "1",
    "CLAUDE_CODE_ENABLE_TOKEN_USAGE_ATTACHMENT": "1",
    "CLAUDE_CODE_NEW_INIT": "1",
    "CLAUDE_CODE_PLAN_MODE_INTERVIEW_PHASE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    //"CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "defaultMode": "default"
  },
  "model": "opusplan",
  "enabledPlugins": {
    "ember@dotknewt-claude-plugins": true,
    "memory-management@dotknewt-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "dotknewt-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "dotknewt/agency"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "medium",
  "advisorModel": "claude-opus-4-7",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "theme": "auto",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
